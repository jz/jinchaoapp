# KataGo paths (relative to repo root, or absolute)
KATAGO_PATH=./katago_bin/katago
KATAGO_MODEL=./models/model.bin.gz
KATAGO_CONFIG=./config/gtp.cfg

# Flask
PORT=5000
FLASK_DEBUG=0

# Google OAuth (optional — leave empty to disable Google Sign-In)
# Get your client ID from https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
